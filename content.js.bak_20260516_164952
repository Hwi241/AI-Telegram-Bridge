  `;

  document.head.appendChild(style);
  document.body.appendChild(panel);

  // ── 드래그 ──
  const title = document.getElementById('ctb-title');
  let dragging = false, dragX = 0, dragY = 0;
  title.addEventListener('mousedown', (e) => {
    dragging = true;
    dragX = e.clientX - panel.getBoundingClientRect().left;
    dragY = e.clientY - panel.getBoundingClientRect().top;
    panel.style.right = 'auto'; panel.style.bottom = 'auto';
    e.preventDefault();
  });
  document.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    panel.style.left = (e.clientX - dragX) + 'px';
    panel.style.top  = (e.clientY - dragY) + 'px';
  });
  document.addEventListener('mouseup', () => { dragging = false; });

  // ── 컨트롤 버튼 ──
  document.getElementById('ctb-refresh').addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('ctb-refresh').classList.add('spinning');
    setTimeout(() => location.reload(), 400);
  });

  let isMinimized = false;
  const body = document.getElementById('ctb-body');

  function minimize() {
    isMinimized = true;
    body.style.display = 'none';
    document.getElementById('ctb-controls').style.display = 'none';
    panel.style.width = '36px'; panel.style.height = '36px';
    panel.style.borderRadius = '50%'; panel.style.padding = '0';
    panel.style.display = 'flex'; panel.style.justifyContent = 'center'; panel.style.alignItems = 'center';
    panel.style.cursor = 'pointer';
    document.getElementById('ctb-title').style.marginBottom = '0';
    document.getElementById('ctb-title').style.cursor = 'pointer';
    document.getElementById('ctb-title-text').style.fontSize = '18px';
    document.getElementById('ctb-title-text').textContent = '🔗';
  }

  function restore() {
    isMinimized = false;
    body.style.display = '';
    document.getElementById('ctb-controls').style.display = '';
    panel.style.width = '130px'; panel.style.height = '';
    panel.style.borderRadius = '12px'; panel.style.padding = '9px 10px';
    panel.style.display = ''; panel.style.justifyContent = ''; panel.style.alignItems = '';
    panel.style.cursor = '';
    document.getElementById('ctb-title').style.marginBottom = '7px';
    document.getElementById('ctb-title').style.cursor = 'grab';
    document.getElementById('ctb-title-text').style.fontSize = '10px';
    document.getElementById('ctb-title-text').textContent = `🔗 ${SITE_NAME}`;
  }

  document.getElementById('ctb-minimize').addEventListener('click', (e) => { e.stopPropagation(); minimize(); });
  panel.addEventListener('click', () => { if (isMinimized) restore(); });
  document.getElementById('ctb-close').addEventListener('click', (e) => { e.stopPropagation(); panel.style.display = 'none'; });

  // ── 복사 모드 토글 ──
  const modeFullBtn = document.getElementById('ctb-mode-full');
  const modeCodeBtn = document.getElementById('ctb-mode-code');

  modeFullBtn.addEventListener('click', () => {
    copyMode = 'full';
    modeFullBtn.classList.add('ctb-mode-active');
    modeCodeBtn.classList.remove('ctb-mode-active');
  });
  modeCodeBtn.addEventListener('click', () => {
    copyMode = 'code';
    modeCodeBtn.classList.add('ctb-mode-active');
    modeFullBtn.classList.remove('ctb-mode-active');
  });

  // ── 상태 ──
  const statusEl = document.getElementById('ctb-status');
  const btn1 = document.getElementById('ctb-btn1');
  const btn2 = document.getElementById('ctb-btn2');

  function setStatus(msg, type = '') { statusEl.textContent = msg; statusEl.className = type; }
  function setBtnsDisabled(v) { btn1.disabled = v; btn2.disabled = v; }

  // ── 버튼 1: AI → Telegram ──
  btn1.addEventListener('click', () => {
    const autoSend = document.getElementById('ctb-autosend').checked;
    setBtnsDisabled(true);
    setStatus('⏳ 처리 중...');
    chrome.runtime.sendMessage({ action: 'aiToTelegram', autoSend }, (res) => {
      setBtnsDisabled(false);
      if (chrome.runtime.lastError) { setStatus(`❌ ${chrome.runtime.lastError.message}`, 'err'); return; }
      if (res?.ok) setStatus('✅ Telegram 전송!', 'ok');
      else         setStatus(`❌ ${res?.error || '실패'}`, 'err');
    });
  });

  // ── 버튼 2: Telegram → AI ──
  btn2.addEventListener('click', () => {
    const autoSend = document.getElementById('ctb-autosend').checked;
    setBtnsDisabled(true);
    setStatus('⏳ 처리 중...');
    chrome.runtime.sendMessage({ action: 'telegramToAI', autoSend }, (res) => {
      setBtnsDisabled(false);
      if (chrome.runtime.lastError) { setStatus(`❌ ${chrome.runtime.lastError.message}`, 'err'); return; }
      if (res?.ok) setStatus(autoSend ? `✅ ${SITE_NAME} 전송!` : `✅ ${SITE_NAME} 입력!`, 'ok');
      else         setStatus(`❌ ${res?.error || '실패'}`, 'err');
    });
  });
}

// ────────────────────────────────────────
// 토큰 카운터
// ────────────────────────────────────────
function injectTokenCounter() {
  if (document.getElementById('ctb-token-counter')) return;
  const counter = document.createElement('div');
  counter.id = 'ctb-token-counter';
  document.body.appendChild(counter);

  function update() {
    const input = getInputEl();
    if (!input) { counter.textContent = ''; return; }
    const rect   = input.getBoundingClientRect();
    const text   = input.innerText || input.value || '';
    const tokens = estimateTokens(text);
    if (!text.trim()) { counter.textContent = ''; return; }
    counter.style.left = (rect.right - 65 + window.scrollX) + 'px';
    counter.style.top  = (rect.bottom - 18 + window.scrollY) + 'px';
    counter.textContent = `~${tokens} tokens`;
    counter.className = tokens > 3000 ? 'danger' : tokens > 1500 ? 'warn' : '';
  }

  document.addEventListener('input', update, true);
  setInterval(update, 800);
}

// ────────────────────────────────────────
// 메시지 리스너
// ────────────────────────────────────────
chrome.runtime.onMessage.addListener((msg, _sender, sendResponse) => {
  if (msg.action === 'getResponse') {
    sendResponse({ text: getResponse() });
    return true;
  }
  if (msg.action === 'checkStreaming') {
    sendResponse({ streaming: isStreaming() });
    return true;
  }
  if (msg.action === 'pasteToAI') {
    pasteToAI(msg.text, msg.autoSend).then(sendResponse);
    return true;
  }
  if (msg.action === 'getTelegramMessage') {
    sendResponse({ text: telegram_getLastMessage() });
    return true;
  }
  if (msg.action === 'sendToTelegram') {
    telegram_sendMessage(msg.text, msg.autoSend).then(sendResponse);
    return true;
  }
});

// ── AI 사이트에서만 UI 주입 ──
if (SITE && SITE !== 'telegram') {
  if (document.body) {
    injectFloatingUI();
    injectTokenCounter();
  } else {
    document.addEventListener('DOMContentLoaded', () => {
      injectFloatingUI();
      injectTokenCounter();
    });
  }
}
